---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';
import { getTopLevelCategoryFromId, sortPostsByDateDesc } from '../lib/posts';

const allPosts = await getCollection('blog');
const posts = sortPostsByDateDesc(allPosts).slice(0, 12);

const title = 'Recent posts';
const description = 'Recent writing — folder-based categories, minimal layout.';
---

<Layout title={title} description={description}>
	<h1 class="mb-2 text-2xl font-semibold tracking-tight text-zinc-900">Recent posts</h1>
	<p class="mb-10 text-sm text-zinc-600">Latest entries across all categories.</p>

	<ul class="flex flex-col gap-8">
		{
			posts.map((post) => {
				const category = getTopLevelCategoryFromId(post.id);
				const date = post.data.pubDate.toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				});
				return (
					<li class="border-b border-zinc-200/90 pb-8 last:border-0">
						<a href={`/blog/${post.id}`} class="group block">
							<h2 class="text-lg font-medium text-zinc-900 group-hover:text-zinc-600">
								{post.data.title}
							</h2>
							<p class="mt-1 line-clamp-2 text-sm text-zinc-600">{post.data.description}</p>
							<div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
								<time datetime={post.data.pubDate.toISOString()}>{date}</time>
								<span aria-hidden="true">·</span>
								<span class="rounded-full bg-zinc-200/80 px-2 py-0.5 font-medium text-zinc-700">
									{category}
								</span>
							</div>
						</a>
					</li>
				);
			})
		}
	</ul>
</Layout>
