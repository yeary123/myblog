---
import Layout from '../components/Layout.astro';
---

<Layout title="Page not found" description="The page you requested does not exist.">
	<h1 class="text-xl font-semibold text-zinc-900">404</h1>
	<p class="mt-2 text-sm text-zinc-600">
		This page does not exist.{' '}
		<a href={import.meta.env.BASE_URL} class="text-zinc-900 underline underline-offset-4">Back home</a>
	</p>
</Layout>
