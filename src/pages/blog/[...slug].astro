---
import Layout from '../../components/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
	}));
}

const slug = Astro.params.slug!;
const post = await getEntry('blog', slug);
if (!post) {
	return Astro.redirect('/404');
}

const { Content } = await render(post);

const title = post.data.title;
const description = post.data.description;
const category = post.id.split('/')[0];
---

<Layout title={title} description={description}>
	<article>
		<p class="mb-2 text-xs font-medium uppercase tracking-wider text-zinc-500">
			<a href={`${import.meta.env.BASE_URL}blog/${category}`} class="transition hover:text-zinc-800 capitalize">
				{category}
			</a>
		</p>
		<h1 class="mb-3 text-3xl font-semibold tracking-tight text-zinc-900 sm:text-4xl">
			{post.data.title}
		</h1>
		<p class="mb-8 text-sm text-zinc-600">{post.data.description}</p>
		<time
			class="mb-10 block text-sm text-zinc-500"
			datetime={post.data.pubDate.toISOString()}
		>
			{
				post.data.pubDate.toLocaleDateString('en-US', {
					year: 'numeric',
					month: 'long',
					day: 'numeric',
				})
			}
		</time>

		{
			post.data.heroImage && (
				<div class="mb-10 overflow-hidden rounded-lg border border-zinc-200/80 shadow-sm">
					<Image
						src={post.data.heroImage}
						alt=""
						class="h-auto w-full"
						loading="eager"
						decoding="async"
						sizes="(max-width: 768px) 100vw, 42rem"
					/>
				</div>
			)
		}

		<div
			class="prose prose-zinc max-w-none prose-headings:scroll-mt-24 prose-headings:font-semibold prose-a:text-zinc-900 prose-a:underline prose-a:decoration-zinc-400 prose-a:underline-offset-4 hover:prose-a:decoration-zinc-900 prose-pre:border prose-pre:border-zinc-200 prose-pre:bg-zinc-900 prose-pre:text-zinc-100 prose-code:text-zinc-800 prose-code:before:content-none prose-code:after:content-none prose-img:rounded-lg prose-img:border prose-img:border-zinc-200/80"
		>
			<Content />
		</div>
	</article>
</Layout>
